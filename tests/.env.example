# Copy this file to tests/.env and fill in the values for roles you've
# created in your dev environment. tests/.env is gitignored — passwords
# never reach the repo. Only roles you actually populate will run;
# the rest skip cleanly.
#
#   cp tests/.env.example tests/.env
#   # edit tests/.env with real values

SOLCLEAR_BASE_URL=http://localhost:8080

# Superadmin (you)
TEST_SUPERADMIN_EMAIL=
TEST_SUPERADMIN_PASSWORD=

# Org admin (e.g. micah@independentsolar.com)
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
# The admin's user_id, used by impersonation tests.
# Look it up with:  SELECT id, email, role FROM users;
TEST_ADMIN_USER_ID=

# Reviewer
TEST_REVIEWER_EMAIL=
TEST_REVIEWER_PASSWORD=

# Crew
TEST_CREW_EMAIL=
TEST_CREW_PASSWORD=
