# CompanyCam API Key — generate at: https://app.companycam.com/developers
COMPANYCAM_API_KEY=

# Anthropic API Key — used for Claude Vision photo compliance checks
ANTHROPIC_API_KEY=

# PostgreSQL on Railway
DATABASE_URL=

# Session secret — used to sign session cookies. Generate a random string for production.
SESSION_SECRET=

# Encryption key for API keys at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Resend API Key — used for password reset emails
RESEND_API_KEY=

# From email for password resets (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@solclear.io
